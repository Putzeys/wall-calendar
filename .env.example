HOST=0.0.0.0
PORT=5000
TIMEZONE=America/Sao_Paulo

OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:3b

# Vírgula separa múltiplas. "primary" é a sua agenda principal.
# Para a Cheila, ela compartilha contigo e o ID fica algo como
# pessoa@gmail.com ou um hash longo @group.calendar.google.com.
CALENDAR_IDS=primary

# Onde novos eventos vão parar. Use "primary" para a conta autenticada
# (recomendado) ou um ID de agenda onde tu tem accessRole=owner/writer.
# Veja /whoami pra confirmar qual conta foi usada no OAuth.
WRITE_CALENDAR=primary
