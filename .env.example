HOST=0.0.0.0
PORT=5000
TIMEZONE=America/Sao_Paulo

OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:3b

# Sintaxe de cada item (vírgula separa):
#   id                       — agenda na conta "main" (token.json)
#   id|Nome                  — id com nome customizado na barra
#   conta::id|Nome           — agenda em outra conta (token_<conta>.json)
#
# Pra adicionar uma conta extra: `python auth.py prototipeai`
# Ordem aqui define a ordem dos filtros e a cor de cada agenda.
CALENDAR_IDS=primary

# Onde novos eventos vão parar. Use "primary" pra cair na conta "main"
# autenticada, ou "conta::id" pra escrever em outra conta. Precisa de
# accessRole=owner ou writer (veja /whoami e /calendars).
WRITE_CALENDAR=primary
